# ============================================================
# Resume Builder AI — Docker Compose uchun muhit o'zgaruvchilari
# Bu faylni nusxalab .env nomli fayl yarating:
#   cp .env.example .env
# ============================================================

# ── Majburiy ────────────────────────────────────────────────
# Anthropic Claude API kaliti (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key-here

# ── Ixtiyoriy: Django ───────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=True

# ── Ixtiyoriy: Email (Gmail SMTP) ──────────────────────────
# Gmail da "App Password" yarating (2FA yoqilgan bo'lishi kerak)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Ixtiyoriy: AWS S3 (PDF saqlash) ────────────────────────
# Bo'sh qoldirsangiz, PDF fayllar local saqlanadi
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
